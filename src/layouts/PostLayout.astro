---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;
---

<BaseLayout
  title={`${title} — Alex Hagemeister`}
  description={description ?? ""}
  currentPath="/blog/"
>
  <main class="container">
    <article>
      <header>
        <h1>{title}</h1>
        <time datetime={date.toISOString()}
          >{
            date.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }</time
        >
      </header>

      <div class="content">
        <slot />
      </div>

      <a class="back-link" href="/blog/">← Back to Blog</a>
    </article>
  </main>
</BaseLayout>

<style>
  main {
    padding: 72px 24px 110px;
  }

  h1 {
    font-family: "Playfair Display", serif;
    font-size: 2.35rem;
    font-weight: 400;
    margin: 0 0 12px;
  }

  time {
    color: var(--fg-muted);
    font-size: 0.9rem;
  }

  .content {
    margin-top: 42px;
    color: var(--fg-muted);
    max-width: 65ch;
  }

  .content :global(p) {
    margin: 0 0 20px;
  }

  .content :global(h2) {
    color: var(--fg);
    font-family: "Playfair Display", serif;
    font-weight: 400;
    margin: 36px 0 16px;
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .content :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  .content :global(strong) {
    color: var(--fg);
  }

  .content :global(blockquote) {
    margin: 0 0 20px;
    padding: 4px 0 4px 20px;
    border-left: 2px solid var(--accent);
    color: var(--fg-muted);
    font-style: italic;
  }

  .content :global(code) {
    font-family: "Menlo", "Monaco", monospace;
    font-size: 0.875em;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 5px;
    color: var(--fg);
  }

  .content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 18px 20px;
    overflow-x: auto;
    margin: 0 0 20px;
  }

  .content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.85em;
    line-height: 1.7;
  }

  .content :global(ul),
  .content :global(ol) {
    margin: 0 0 20px;
    padding-left: 24px;
  }

  .content :global(li) {
    margin-bottom: 6px;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 36px 0;
  }

  .back-link {
    display: inline-block;
    margin-top: 32px;
    text-decoration: none;
    color: var(--fg-muted);
  }

  .back-link:hover {
    color: var(--accent);
  }
</style>
