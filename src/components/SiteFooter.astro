---
const { compact = false } = Astro.props as { compact?: boolean };
---

<footer class={`site-footer ${compact ? "compact" : ""}`}>
  <div class="container"></div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 32px 0 48px;
  }

  .site-footer.compact {
    padding: 24px 0 32px;
  }
</style>
