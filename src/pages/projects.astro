---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects — Alex Hagemeister"
  description="Current and upcoming projects by Alex Hagemeister."
  currentPath="/projects/"
>
  <main class="container projects-page">
    <h1>Projects</h1>
    <p class="status">
      Standalone project pages are being built out. In the meantime:
    </p>
    <nav class="next-actions" aria-label="Next steps">
      <a href="/#projects">Selected work on home page →</a>
      <a
        href="https://github.com/AlexHagemeister"
        target="_blank"
        rel="noreferrer">Code on GitHub →</a
      >
      <a href="/blog/">Writing on the blog →</a>
    </nav>
  </main>
</BaseLayout>

<style>
  .projects-page {
    padding: 80px 24px 120px;
    min-height: 60vh;
  }

  h1 {
    font-family: "Playfair Display", serif;
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  .status {
    margin: 0 0 32px;
    color: var(--fg-muted);
    font-size: 1.05rem;
  }

  .next-actions {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .next-actions a {
    text-decoration: none;
    color: var(--fg-muted);
    font-size: 1rem;
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    width: fit-content;
  }

  .next-actions a:hover {
    color: var(--fg);
    border-bottom-color: var(--fg-muted);
  }
</style>
