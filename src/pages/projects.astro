---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects — Alex Hagemeister"
  description="Current and upcoming projects by Alex Hagemeister."
  currentPath="/projects/"
>
  <main class="container projects-page">
    <h1>Projects</h1>
    <p>
      Selected standalone projects are being migrated and expanded. More detail
      landing soon.
    </p>
  </main>
</BaseLayout>

<style>
  .projects-page {
    padding: 80px 24px 120px;
    min-height: 60vh;
  }

  h1 {
    font-family: "Playfair Display", serif;
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }

  p {
    margin: 0;
    color: var(--fg-muted);
    font-size: 1.05rem;
  }
</style>
