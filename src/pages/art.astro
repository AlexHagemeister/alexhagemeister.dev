---
import BaseLayout from '../layouts/BaseLayout.astro';

interface GalleryImage {
	src: string;
	alt: string;
	caption: string;
}

interface ArtProject {
	title: string;
	meta: string;
	description: string;
	images: GalleryImage[];
}

const projects: ArtProject[] = [
	{
		title: 'The Mazu Temple',
		meta: '2015 · The Dream Community',
		description:
			'A temple inspired by traditional Chinese temples dedicated to the goddess Mazu, with a lotus centerpiece and fire-breathing dragons.',
		images: [
			{ src: '/images/15.jpg', alt: 'Main entrance at night', caption: 'Main entrance at night. Image credit: Wobserazzi' },
			{ src: '/images/16.jpg', alt: 'Lotus petals up close', caption: 'Lotus petals up close. Image credit: Aleksey Bochovsky' },
			{ src: '/images/17.jpg', alt: 'Dragons at ground level', caption: 'Dragons at ground level. Image credit: Aleksey Bochovsky' },
			{ src: '/images/18.jpg', alt: 'Lotus crane lift during build', caption: 'Lotus crane lift during build. Image credit: Aleksey Bochovsky' },
			{ src: '/images/19.jpg', alt: 'Burn ceremony', caption: 'Burn ceremony. Image credit: Wobserazzi' },
		],
	},
	{
		title: 'Embrace',
		meta: '2014 · The Pier Group',
		description:
			'A pair of towering wooden human forms in an embrace, with interior staircases and elevated viewpoints inside each structure.',
		images: [
			{ src: '/images/11.jpg', alt: 'Crew photo at Embrace', caption: "Crew photo (I'm far left, freshly down from a boom lift)." },
			{ src: '/images/12.jpg', alt: 'Blueprint work on Embrace', caption: 'Blueprint work. Image credit: The Dusty Fish' },
			{ src: '/images/13.jpg', alt: 'View inside Embrace head', caption: 'View inside the head. Image credit: Galen Oakes' },
			{ src: '/images/14.jpg', alt: 'Embrace burn', caption: 'Burn. Image credit: Art Gimbel' },
		],
	},
	{
		title: 'La Llorona Spanish Galleon',
		meta: '2012 · The Pier Group',
		description:
			'Full-scale Spanish galleon replica wrecked on a pier, with furnished interiors and immersive storytelling environments.',
		images: [
			{ src: '/images/4.jpg', alt: 'La Llorona galleon exterior', caption: 'Image credit: Shay Harting, 2012' },
			{ src: '/images/5.jpg', alt: 'Hull rib installation', caption: 'Installing hull ribs during build' },
			{ src: '/images/6.jpg', alt: 'La Llorona crew photo', caption: 'Crew photo' },
			{ src: '/images/7.jpg', alt: 'La Llorona at night', caption: 'Image credit: Grant Kaye, Smithsonian Magazine' },
		],
	},
	{
		title: 'The Temple of Transition',
		meta: '2011 · International Arts Megacrew',
		description:
			'A 120-foot temporary wooden temple with six outer structures and bridges, used as a collective site for reflection and grief.',
		images: [
			{ src: '/images/1.jpg', alt: 'Temple of Transition at night', caption: 'Image credit: Bentley Meeker, 2011' },
			{ src: '/images/2.jpg', alt: 'Temple of Transition in dust', caption: 'Image credit: Scott London' },
			{ src: '/images/3.jpg', alt: 'Temple of Transition burn', caption: 'Image credit: Reuters/Daily Mail' },
		],
	},
];
---

<BaseLayout title="Art — Alex Hagemeister" description="Large-scale art and build work by Alex Hagemeister." currentPath="/art/">
	<main class="container">
		<header>
			<h1>Big Art</h1>
			<p>
				These photos document large-scale immersive art installations built for Burning Man, spanning design,
				carpentry, metalwork, pyrotechnics, and onsite production.
			</p>
		</header>

		{
			projects.map((project) => (
				<section class="project">
					<h2>
						{project.title} <span>{project.meta}</span>
					</h2>
					<p>{project.description}</p>
					<div class="gallery-wrapper">
						<div class="gallery">
							{project.images.map((image) => (
								<div class="gallery-item">
									<img src={image.src} alt={image.alt} />
									<p class="caption">{image.caption}</p>
								</div>
							))}
						</div>
						<div class="scroll-hint" aria-hidden="true">→</div>
					</div>
				</section>
			))
		}

		<div class="back">
			<a href="/">← Back to work</a>
		</div>
	</main>

	<div class="lightbox" id="lightbox">
		<button class="close" id="close-lightbox" type="button" aria-label="Close image preview">&times;</button>
		<img id="lightbox-img" src="" alt="" />
		<div class="caption-lightbox" id="lightbox-caption"></div>
	</div>
</BaseLayout>

<script>
	const lightbox = document.getElementById('lightbox');
	const lightboxImage = document.getElementById('lightbox-img');
	const lightboxCaption = document.getElementById('lightbox-caption');
	const closeButton = document.getElementById('close-lightbox');

	const closeLightbox = () => {
		lightbox?.classList.remove('active');
	};

	document.querySelectorAll('.gallery-item img').forEach((img) => {
		img.addEventListener('click', () => {
			if (!(img instanceof HTMLImageElement)) return;
			const caption = img.parentElement?.querySelector('.caption');
			if (!(lightboxImage instanceof HTMLImageElement) || !(lightboxCaption instanceof HTMLDivElement)) return;
			lightboxImage.src = img.src;
			lightboxImage.alt = img.alt;
			lightboxCaption.textContent = caption?.textContent ?? '';
			lightboxCaption.style.display = caption?.textContent ? 'block' : 'none';
			lightbox?.classList.add('active');
		});
	});

	document.querySelectorAll('.gallery').forEach((gallery) => {
		const updateScrolledState = () => {
			if (!(gallery instanceof HTMLElement)) return;
			if (gallery.scrollLeft > 10) {
				gallery.classList.add('scrolled');
			} else {
				gallery.classList.remove('scrolled');
			}
		};

		gallery.addEventListener('scroll', () => {
			updateScrolledState();
		});

		updateScrolledState();
	});

	closeButton?.addEventListener('click', closeLightbox);
	lightbox?.addEventListener('click', (event) => {
		if (event.target === lightbox) closeLightbox();
	});
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeLightbox();
	});
</script>

<style>
	.container {
		max-width: 960px;
	}

	header {
		padding: 72px 0 54px;
	}

	header h1 {
		font-family: 'Playfair Display', serif;
		font-size: 2.3rem;
		font-weight: 400;
		margin: 0 0 18px;
	}

	header p {
		color: var(--fg-muted);
		max-width: 80ch;
		margin: 0;
	}

	.project {
		padding: 52px 0;
		border-top: 1px solid var(--border);
	}

	.project h2 {
		font-family: 'Playfair Display', serif;
		font-weight: 400;
		font-size: 1.45rem;
		margin: 0 0 16px;
	}

	.project h2 span {
		color: var(--fg-muted);
		font-size: 1rem;
		font-weight: 300;
	}

	.project > p {
		color: var(--fg-muted);
		margin: 0 0 32px;
	}

	.gallery-wrapper {
		position: relative;
	}

	.gallery-wrapper::after {
		content: '';
		position: absolute;
		top: 0;
		right: 0;
		bottom: 20px;
		width: 64px;
		background: linear-gradient(to right, transparent, var(--bg));
		pointer-events: none;
	}

	.gallery {
		display: flex;
		gap: 18px;
		overflow-x: auto;
		padding-bottom: 20px;
		scroll-snap-type: x mandatory;
		scrollbar-width: none;
	}

	.gallery::-webkit-scrollbar {
		display: none;
	}

	.gallery-item {
		flex: 0 0 auto;
		scroll-snap-align: start;
	}

	.gallery-item img {
		height: 380px;
		width: auto;
		cursor: zoom-in;
		display: block;
	}

	.caption {
		margin: 10px 0 0;
		max-width: 380px;
		font-size: 0.78rem;
		color: var(--fg-muted);
		font-style: italic;
	}

	.scroll-hint {
		position: absolute;
		top: 50%;
		right: 14px;
		transform: translateY(-50%);
		color: var(--fg-muted);
		background: rgb(10 10 10 / 50%);
		padding: 2px 9px;
		border-radius: 4px;
		pointer-events: none;
	}

	.gallery.scrolled ~ .scroll-hint {
		opacity: 0;
	}

	.back {
		text-align: center;
		padding: 42px 0 100px;
	}

	.back a {
		text-decoration: none;
		color: var(--fg-muted);
	}

	.back a:hover {
		color: var(--fg);
	}

	.lightbox {
		display: none;
		position: fixed;
		inset: 0;
		background: rgb(10 10 10 / 95%);
		z-index: 1000;
		align-items: center;
		justify-content: center;
		padding: 40px;
	}

	.lightbox.active {
		display: flex;
	}

	.lightbox img {
		max-width: 90%;
		max-height: 90%;
		object-fit: contain;
	}

	.close {
		position: absolute;
		top: 20px;
		right: 20px;
		font-size: 2rem;
		background: none;
		color: var(--fg);
		border: 0;
		cursor: pointer;
	}

	.caption-lightbox {
		position: absolute;
		bottom: 24px;
		left: 50%;
		transform: translateX(-50%);
		color: var(--fg-muted);
		font-style: italic;
	}

	@media (max-width: 640px) {
		.gallery-item img {
			height: 220px;
		}
	}
</style>
