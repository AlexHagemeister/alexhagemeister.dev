---
import BaseLayout from "../layouts/BaseLayout.astro";

interface GalleryImage {
  src: string;
  alt: string;
  caption: string;
}

interface ArtProject {
  title: string;
  meta: string;
  description: string;
  images: GalleryImage[];
}

const projects: ArtProject[] = [
  {
    title: "The Mazu Temple",
    meta: "2015 · The Dream Community",
    description:
      "A temple inspired by traditional Chinese temples dedicated to the goddess Mazu, with a lotus centerpiece and fire-breathing dragons.",
    images: [
      {
        src: "/images/15.jpg",
        alt: "Main entrance at night",
        caption: "Main entrance at night. Image credit: Wobserazzi",
      },
      {
        src: "/images/16.jpg",
        alt: "Lotus petals up close",
        caption: "Lotus petals up close. Image credit: Aleksey Bochovsky",
      },
      {
        src: "/images/17.jpg",
        alt: "Dragons at ground level",
        caption: "Dragons at ground level. Image credit: Aleksey Bochovsky",
      },
      {
        src: "/images/18.jpg",
        alt: "Lotus crane lift during build",
        caption:
          "Lotus crane lift during build. Image credit: Aleksey Bochovsky",
      },
      {
        src: "/images/19.jpg",
        alt: "Burn ceremony",
        caption: "Burn ceremony. Image credit: Wobserazzi",
      },
    ],
  },
  {
    title: "Embrace",
    meta: "2014 · The Pier Group",
    description:
      "A pair of towering wooden human forms in an embrace, with interior staircases and elevated viewpoints inside each structure.",
    images: [
      {
        src: "/images/11.jpg",
        alt: "Crew photo at Embrace",
        caption: "Crew photo (I'm far left, freshly down from a boom lift).",
      },
      {
        src: "/images/12.jpg",
        alt: "Blueprint work on Embrace",
        caption: "Blueprint work. Image credit: The Dusty Fish",
      },
      {
        src: "/images/13.jpg",
        alt: "View inside Embrace head",
        caption: "View inside the head. Image credit: Galen Oakes",
      },
      {
        src: "/images/14.jpg",
        alt: "Embrace burn",
        caption: "Burn. Image credit: Art Gimbel",
      },
    ],
  },
  {
    title: "La Llorona Spanish Galleon",
    meta: "2012 · The Pier Group",
    description:
      "Full-scale Spanish galleon replica wrecked on a pier, with furnished interiors and immersive storytelling environments.",
    images: [
      {
        src: "/images/4.jpg",
        alt: "La Llorona galleon exterior",
        caption: "Image credit: Shay Harting, 2012",
      },
      {
        src: "/images/5.jpg",
        alt: "Hull rib installation",
        caption: "Installing hull ribs during build",
      },
      {
        src: "/images/6.jpg",
        alt: "La Llorona crew photo",
        caption: "Crew photo",
      },
      {
        src: "/images/7.jpg",
        alt: "La Llorona at night",
        caption: "Image credit: Grant Kaye, Smithsonian Magazine",
      },
    ],
  },
  {
    title: "The Temple of Transition",
    meta: "2011 · International Arts Megacrew",
    description:
      "A 120-foot temporary wooden temple with six outer structures and bridges, used as a collective site for reflection and grief.",
    images: [
      {
        src: "/images/1.jpg",
        alt: "Temple of Transition at night",
        caption: "Image credit: Bentley Meeker, 2011",
      },
      {
        src: "/images/2.jpg",
        alt: "Temple of Transition in dust",
        caption: "Image credit: Scott London",
      },
      {
        src: "/images/3.jpg",
        alt: "Temple of Transition burn",
        caption: "Image credit: Reuters/Daily Mail",
      },
    ],
  },
];

const allImages = projects.flatMap((p) => p.images);
---

<BaseLayout
  title="Art — Alex Hagemeister"
  description="Large-scale art and build work by Alex Hagemeister."
  currentPath="/art/"
>
  <main class="container">
    <header>
      <h1>Big Art</h1>
      <p>
        These photos document large-scale immersive art installations built for
        Burning Man, spanning design, carpentry, metalwork, pyrotechnics, and
        onsite production.
      </p>
    </header>

    {
      projects.map((project) => (
        <section class="project">
          <h2>
            {project.title} <span>{project.meta}</span>
          </h2>
          <p>{project.description}</p>
          <div class="gallery-wrapper">
            <div class="gallery">
              {project.images.map((image) => (
                <div class="gallery-item">
                  <img
                    src={image.src}
                    alt={image.alt}
                    tabindex="0"
                    role="button"
                    data-index={allImages.indexOf(image)}
                  />
                  <p class="caption">{image.caption}</p>
                </div>
              ))}
            </div>
            <div class="scroll-hint" aria-hidden="true">
              →
            </div>
          </div>
        </section>
      ))
    }

    <div class="back">
      <a href="/">← Back to work</a>
    </div>
  </main>

  <div class="lightbox" id="lightbox">
    <button
      class="close"
      id="close-lightbox"
      type="button"
      aria-label="Close image preview">&times;</button
    >
    <div class="lb-track" id="lb-track">
      {
        allImages.map((image) => (
          <div class="lb-slide">
            <img src={image.src} alt={image.alt} />
            {image.caption && <p class="lb-caption">{image.caption}</p>}
          </div>
        ))
      }
    </div>
    <button
      class="nav-btn prev-btn"
      id="lightbox-prev"
      type="button"
      aria-label="Previous image">&#8249;</button
    >
    <button
      class="nav-btn next-btn"
      id="lightbox-next"
      type="button"
      aria-label="Next image">&#8250;</button
    >
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById("lightbox");
  const track = document.getElementById("lb-track") as HTMLElement | null;
  const slides = Array.from(
    document.querySelectorAll<HTMLElement>(".lb-slide"),
  );
  const closeButton = document.getElementById("close-lightbox");
  const prevButton = document.getElementById("lightbox-prev");
  const nextButton = document.getElementById("lightbox-next");

  let current = 0;
  let activeTrigger: HTMLElement | null = null;

  // ── Zoom state (applied to each slide's img) ──────────────────────────────
  const MAX_SCALE = 4;
  let scale = 1;
  let zoomTX = 0;
  let zoomTY = 0;

  const currentImg = () =>
    slides[current]?.querySelector("img") as HTMLImageElement | null;

  const applyZoom = () => {
    const img = currentImg();
    if (!img) return;
    img.style.transform =
      scale === 1 ? "" : `translate(${zoomTX}px, ${zoomTY}px) scale(${scale})`;
    img.style.cursor = scale > 1 ? "grab" : "zoom-in";
  };

  const resetZoom = () => {
    const img = currentImg();
    if (img) {
      img.style.transform = "";
      img.style.cursor = "zoom-in";
    }
    scale = 1;
    zoomTX = 0;
    zoomTY = 0;
  };

  // ── Sliding track ─────────────────────────────────────────────────────────
  const slideW = () => window.innerWidth;

  const goTo = (index: number, animate = true) => {
    resetZoom();
    current = ((index % slides.length) + slides.length) % slides.length;
    if (!track) return;
    track.style.transition = animate
      ? "transform 300ms cubic-bezier(0.25, 0.46, 0.45, 0.94)"
      : "none";
    track.style.transform = `translateX(${-current * slideW()}px)`;
  };

  const openLightbox = (index: number, trigger: HTMLElement | null) => {
    activeTrigger = trigger;
    goTo(index, false);
    lightbox?.classList.add("active");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      if (closeButton instanceof HTMLButtonElement) closeButton.focus();
    });
  };

  const closeLightbox = () => {
    resetZoom();
    lightbox?.classList.remove("active");
    document.body.style.overflow = "";
    const target =
      activeTrigger instanceof HTMLElement && activeTrigger.isConnected
        ? activeTrigger
        : document.body;
    target.focus();
    activeTrigger = null;
  };

  // ── Gallery thumbnails ────────────────────────────────────────────────────
  document
    .querySelectorAll<HTMLImageElement>(".gallery-item img")
    .forEach((img) => {
      img.addEventListener("click", () =>
        openLightbox(Number(img.dataset.index ?? 0), img),
      );
      img.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openLightbox(Number(img.dataset.index ?? 0), img);
        }
      });
    });

  // ── Gallery scroll state ──────────────────────────────────────────────────
  document.querySelectorAll(".gallery").forEach((gallery) => {
    const update = () => {
      if (!(gallery instanceof HTMLElement)) return;
      gallery.classList.toggle("scrolled", gallery.scrollLeft > 10);
    };
    gallery.addEventListener("scroll", update);
    update();
  });

  // ── Buttons + keyboard ────────────────────────────────────────────────────
  prevButton?.addEventListener("click", (e) => {
    e.stopPropagation();
    goTo(current - 1);
  });
  nextButton?.addEventListener("click", (e) => {
    e.stopPropagation();
    goTo(current + 1);
  });
  closeButton?.addEventListener("click", closeLightbox);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (!lightbox?.classList.contains("active")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") goTo(current - 1);
    if (e.key === "ArrowRight") goTo(current + 1);
  });

  // ── Drag to navigate / pan when zoomed (mouse) ───────────────────────────
  let isDragging = false;
  let isPanning = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panStartTX = 0;
  let panStartTY = 0;

  lightbox?.addEventListener("mousedown", (e) => {
    if ((e.target as Element).closest(".nav-btn, .close")) return;
    dragStartX = e.clientX;
    dragStartY = e.clientY;
    if (scale > 1) {
      isPanning = true;
      panStartTX = zoomTX;
      panStartTY = zoomTY;
      const img = currentImg();
      if (img) img.style.cursor = "grabbing";
    } else {
      isDragging = true;
      if (track) track.style.transition = "none";
    }
    e.preventDefault();
  });

  document.addEventListener("mousemove", (e) => {
    if (isPanning) {
      zoomTX = panStartTX + (e.clientX - dragStartX);
      zoomTY = panStartTY + (e.clientY - dragStartY);
      applyZoom();
    } else if (isDragging && track) {
      track.style.transform = `translateX(${-current * slideW() + (e.clientX - dragStartX)}px)`;
    }
  });

  document.addEventListener("mouseup", (e) => {
    if (isPanning) {
      isPanning = false;
      const img = currentImg();
      if (img) img.style.cursor = "grab";
    } else if (isDragging) {
      isDragging = false;
      const dx = e.clientX - dragStartX;
      if (dx < -60) goTo(current + 1);
      else if (dx > 60) goTo(current - 1);
      else goTo(current);
    }
  });

  // ── Double-click / double-tap to toggle zoom ──────────────────────────────
  let lastTap = 0;
  const toggleZoom = () => {
    if (scale > 1) {
      resetZoom();
    } else {
      scale = 2.5;
      applyZoom();
    }
  };
  lightbox?.addEventListener("dblclick", (e) => {
    if ((e.target as Element).closest(".nav-btn, .close")) return;
    toggleZoom();
  });

  // ── Touch: pinch zoom + swipe/drag to navigate ────────────────────────────
  let touchStartX = 0;
  let pinchStartDist = 0;
  let pinchStartScale = 1;
  let isPinching = false;

  lightbox?.addEventListener(
    "touchstart",
    (e) => {
      if (e.touches.length === 2) {
        isPinching = true;
        pinchStartDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY,
        );
        pinchStartScale = scale;
      } else if (e.touches.length === 1) {
        touchStartX = e.touches[0].clientX;
        dragStartX = e.touches[0].clientX;
        dragStartY = e.touches[0].clientY;
        if (scale > 1) {
          isPanning = true;
          panStartTX = zoomTX;
          panStartTY = zoomTY;
        } else {
          if (track) track.style.transition = "none";
        }
        // Double-tap
        const now = Date.now();
        if (now - lastTap < 300) {
          e.preventDefault();
          toggleZoom();
        }
        lastTap = now;
      }
    },
    { passive: false },
  );

  lightbox?.addEventListener(
    "touchmove",
    (e) => {
      e.preventDefault();
      if (e.touches.length === 2 && isPinching) {
        const dist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY,
        );
        scale = Math.min(
          MAX_SCALE,
          Math.max(1, pinchStartScale * (dist / pinchStartDist)),
        );
        if (scale === 1) {
          zoomTX = 0;
          zoomTY = 0;
        }
        applyZoom();
      } else if (e.touches.length === 1) {
        const t = e.touches[0];
        if (isPanning) {
          zoomTX = panStartTX + (t.clientX - dragStartX);
          zoomTY = panStartTY + (t.clientY - dragStartY);
          applyZoom();
        } else if (!isPinching && track) {
          track.style.transform = `translateX(${-current * slideW() + (t.clientX - touchStartX)}px)`;
        }
      }
    },
    { passive: false },
  );

  lightbox?.addEventListener("touchend", (e) => {
    if (e.touches.length < 2) isPinching = false;
    if (e.touches.length === 0) {
      if (isPanning) {
        isPanning = false;
      } else if (scale <= 1) {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (dx < -60) goTo(current + 1);
        else if (dx > 60) goTo(current - 1);
        else goTo(current);
      }
    }
  });

  // ── Trackpad: pinch zoom + horizontal swipe ───────────────────────────────
  let lastNavTime = 0;
  lightbox?.addEventListener(
    "wheel",
    (e) => {
      e.preventDefault();
      if (e.ctrlKey) {
        scale = Math.min(
          MAX_SCALE,
          Math.max(1, scale * (1 - e.deltaY * 0.008)),
        );
        if (scale === 1) {
          zoomTX = 0;
          zoomTY = 0;
        }
        applyZoom();
      } else if (
        scale <= 1 &&
        Math.abs(e.deltaX) > Math.abs(e.deltaY) &&
        Math.abs(e.deltaX) > 2
      ) {
        const now = Date.now();
        if (now - lastNavTime > 500) {
          lastNavTime = now;
          if (e.deltaX > 0) goTo(current + 1);
          else goTo(current - 1);
        }
      }
    },
    { passive: false },
  );

  // ── Recalculate position on resize ───────────────────────────────────────
  window.addEventListener("resize", () => {
    if (lightbox?.classList.contains("active")) goTo(current, false);
  });
</script>

<style>
  .container {
    max-width: 960px;
  }

  header {
    padding: 72px 0 54px;
  }

  header h1 {
    font-family: "Playfair Display", serif;
    font-size: 2.3rem;
    font-weight: 400;
    margin: 0 0 18px;
  }

  header p {
    color: var(--fg-muted);
    max-width: 80ch;
    margin: 0;
  }

  .project {
    padding: 52px 0;
    border-top: 1px solid var(--border);
  }

  .project h2 {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.1rem;
    margin: 0 0 16px;
  }

  .project h2 span {
    color: var(--fg-muted);
    font-size: 0.85rem;
    font-weight: 400;
  }

  .project > p {
    color: var(--fg-muted);
    margin: 0 0 32px;
  }

  .gallery-wrapper {
    position: relative;
  }

  .gallery-wrapper::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 20px;
    width: 64px;
    background: linear-gradient(to left, transparent, var(--bg));
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .gallery-wrapper:has(.gallery.scrolled)::before {
    opacity: 1;
  }

  .gallery-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 20px;
    width: 64px;
    background: linear-gradient(to right, transparent, var(--bg));
    pointer-events: none;
  }

  .gallery {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    padding-bottom: 20px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .gallery::-webkit-scrollbar {
    display: none;
  }

  .gallery-item {
    flex: 0 0 auto;
    scroll-snap-align: start;
  }

  .gallery-item img {
    height: 380px;
    width: auto;
    cursor: zoom-in;
    display: block;
  }

  .caption {
    font-family: var(--font-mono);
    margin: 10px 0 0;
    max-width: 380px;
    font-size: 0.72rem;
    color: var(--fg-muted);
    font-style: normal;
  }

  .scroll-hint {
    position: absolute;
    top: 50%;
    right: 14px;
    transform: translateY(-50%);
    color: var(--fg-muted);
    background: rgb(10 10 10 / 50%);
    padding: 2px 9px;
    border-radius: 4px;
    pointer-events: none;
  }

  .gallery.scrolled ~ .scroll-hint {
    opacity: 0;
  }

  .back {
    text-align: center;
    padding: 42px 0 100px;
  }

  .back a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--fg-muted);
  }

  .back a:hover {
    color: var(--accent-cyan);
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgb(10 10 10 / 95%);
    z-index: 1000;
    overflow: hidden;
  }

  .lightbox.active {
    display: block;
  }

  .lb-track {
    display: flex;
    height: 100%;
    will-change: transform;
  }

  .lb-slide {
    flex: 0 0 100vw;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 32px 48px;
    box-sizing: border-box;
  }

  .lb-slide img {
    max-width: 100%;
    max-height: calc(100vh - 130px);
    object-fit: contain;
    cursor: zoom-in;
    user-select: none;
    -webkit-user-drag: none;
    transform-origin: center;
  }

  .lb-caption {
    font-family: var(--font-mono);
    margin-top: 12px;
    color: var(--fg-muted);
    font-style: normal;
    font-size: 0.75rem;
    text-align: center;
    max-width: 480px;
  }

  .close {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 2rem;
    background: none;
    color: var(--fg);
    border: 0;
    cursor: pointer;
    z-index: 10;
  }

  .nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgb(10 10 10 / 60%);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 150ms ease;
    z-index: 10;
  }

  .nav-btn:hover {
    background: rgb(10 10 10 / 90%);
  }

  .prev-btn {
    left: 16px;
  }

  .next-btn {
    right: 16px;
  }

  /* removed .caption-lightbox — captions now live inside .lb-slide */
  .lb-caption-placeholder {
    display: none;
  }

  @media (max-width: 640px) {
    .gallery-item img {
      height: 220px;
    }
  }
</style>
