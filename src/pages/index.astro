---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    title: "Highly Adaptive Ridge",
    description:
      "Co-authored ML research paper as sole undergraduate in UC Berkeley's Center for Targeted Machine Learning.",
    href: "https://arxiv.org/abs/2410.02680",
    linkText: "arXiv:2410.02680",
    skills: ["Python", "NumPy", "SciPy", "scikit-learn", "pandas", "matplotlib"],
  },
  {
    title: "SPLAT — AI Course Tutors, UC Berkeley",
    description:
      "Lead developer on Berkeley-funded EdTech platform for course-specific AI tutors. Built the ingestion, retrieval, generation, and student-facing application layers.",
    skills: ["Python", "React", "RAG", "LangChain", "FastAPI"],
  },
  {
    title: "IT Service Desk Intern — Stanford Research Institute",
    description:
      "Embedded technical support for SRI researchers, handling 300+ service requests in three months and unblocking teams when infrastructure failed.",
    skills: ["IT Support", "Ticketing", "Troubleshooting", "Infrastructure"],
  },
];
---

<BaseLayout
  title="Alex Hagemeister — Portfolio"
  description="Portfolio of Alex Hagemeister. AI/ML infrastructure, RAG systems, and production-focused software."
  currentPath="/"
>
  <main class="container">
    <header class="hero">
      <div class="hero-row">
        <div class="hero-image">
          <img src="/images/profile.png" alt="Portrait of Alex Hagemeister" />
        </div>
        <div class="hero-content">
          <h1>Hi, I'm Alex.</h1>
          <p class="tagline">
            I build things. Most of them interesting, some of them useful.<span
              class="cursor">_</span
            >
          </p>
          <nav aria-label="External links" class="hero-links">
            <a href="mailto:hagemeister.alex@gmail.com">Email</a>
            <a
              href="https://github.com/AlexHagemeister"
              target="_blank"
              rel="noreferrer">GitHub</a
            >
            <a
              href="https://www.linkedin.com/in/alexhagemeister/"
              target="_blank"
              rel="noreferrer">LinkedIn</a
            >
            <a
              href="https://arxiv.org/abs/2410.02680"
              target="_blank"
              rel="noreferrer">Research</a
            >
          </nav>
        </div>
      </div>
    </header>

    <section id="about" class="reveal">
      <h2><span class="prefix">//</span> About</h2>
      <p>
        <strong>B.S. EECS, UC Berkeley, graduating May 2026.</strong> Regents' and
        Chancellor's Scholarship recipient.
      </p>

      <p>
        AI capability is accelerating faster than most can fully grasp, but most
        organizations are still figuring out how to use it for anything beyond
        chatbots and demo days. What AI can technically do will continue to
        outpace what companies and developers can actually get out of them.
      </p>

      <p>
        <strong>That gap is my target for the next 2-5 years:</strong> the infrastructure
        that takes raw AI capability and makes it work inside real workflows with
        messy data and vague requirements.
      </p>

      <p>
        Writing code is getting commoditized. <strong>What isn't:</strong> figuring
        out what needs to exist, designing the system that gets you there, and making
        it run reliably in production.
      </p>
    </section>

    <section id="projects">
      <h2><span class="prefix">//</span> Selected Work</h2>
      {projects.map((project, i) => (
        <div
          class="project reveal"
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="window-chrome"><span></span><span></span><span></span></div>
          <h3><span class="prefix">&gt;</span> {project.title}</h3>
          <p>
            {project.description}
            {project.href && (
              <>
                {" "}
                <a
                  href={project.href}
                  target="_blank"
                  rel="noreferrer"
                >
                  {project.linkText ?? "Link"}
                </a>
              </>
            )}
          </p>
          <ul class="skill-pills" aria-label="Technologies used">
            {project.skills.map((skill) => (
              <li>{skill}</li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <section id="contact">
      <h2 class="reveal"><span class="prefix">//</span> Contact</h2>
      <div class="reveal" style="transition-delay: 80ms">
        <form id="contact-form" class="contact-form">
        <label for="contact-name">Name</label>
        <input
          type="text"
          id="contact-name"
          name="name"
          class="contact-input"
          autocomplete="name"
        />
        <label for="contact-email">Email</label>
        <input
          type="email"
          id="contact-email"
          name="email"
          class="contact-input"
          required
          autocomplete="email"
        />
        <label for="contact-message">Message</label>
        <textarea
          id="contact-message"
          name="message"
          class="contact-input contact-textarea"
          required
          rows="4"></textarea>
        <div class="contact-honeypot" aria-hidden="true">
          <label for="contact-website">Website</label>
          <input
            type="text"
            id="contact-website"
            name="website"
            tabindex="-1"
          />
        </div>
        <button type="submit" class="contact-submit">Send</button>
      </form>
        <p id="form-status" class="contact-status" aria-live="polite"></p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form");
  const status = document.getElementById("form-status");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.textContent = "";
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn instanceof HTMLButtonElement) {
        submitBtn.disabled = true;
      }
      try {
        const formData = new FormData(form as HTMLFormElement);
        const response = await fetch("/api/contact/", {
          method: "POST",
          body: formData,
        });
        const data = (await response.json()) as { message?: string };
        status.textContent =
          data.message ??
          (response.ok ? "Thanks for your message." : "Something went wrong.");
        if (response.ok) {
          (form as HTMLFormElement).reset();
        }
      } catch {
        status.textContent = "Something went wrong.";
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = false;
        }
      }
    });
  }
</script>

<style>
  /* ── Terminal prefix ── */
  .prefix {
    color: var(--accent-cyan);
    margin-right: 8px;
  }

  /* ── Blinking cursor ── */
  .cursor {
    color: var(--accent-cyan);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ── Hero ── */
  .hero {
    padding: 64px 0 42px;
  }

  .hero-row {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .hero-image {
    flex-shrink: 0;
  }

  .hero-image img {
    width: 168px;
    height: 168px;
    object-fit: cover;
    border-radius: 50%;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-content h1 {
    font-family: "Playfair Display", serif;
    font-size: 2.2rem;
    font-weight: 400;
    margin: 0 0 10px;
    color: var(--fg);
  }

  .tagline {
    margin: 0;
    font-size: 1.1rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 24px;
  }

  .hero-links a {
    font-family: var(--font-mono);
    text-decoration: none;
    color: var(--fg-muted);
    font-size: 0.85rem;
  }

  .hero-links a:hover {
    color: var(--accent-cyan);
  }

  /* ── Sections ── */
  section {
    padding: 36px 0;
    border-top: 1px solid var(--border);
  }

  #about {
    border-top: none;
    padding-top: 0;
  }

  h2 {
    font-family: var(--font-mono);
    font-size: 1.15rem;
    font-weight: 600;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg);
    margin: 0 0 24px;
  }

  p {
    color: var(--fg-muted);
    margin: 0 0 18px;
  }

  /* ── Project cards ── */
  .window-chrome {
    display: flex;
    gap: 6px;
    margin-bottom: 14px;
  }

  .window-chrome span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    transition: background 150ms ease;
  }

  .project:hover .window-chrome span:nth-child(1) {
    background: #ec6a5e;
  }

  .project:hover .window-chrome span:nth-child(2) {
    background: #f4bf4f;
  }

  .project:hover .window-chrome span:nth-child(3) {
    background: #61c554;
  }

  .project {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px 24px;
    margin-bottom: 16px;
    transition:
      border-color 150ms ease,
      opacity 0.4s ease,
      transform 0.4s ease;
  }

  .project:hover {
    border-color: var(--accent-cyan);
  }

  .project:last-child {
    margin-bottom: 0;
  }

  .project h3 {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    margin: 0 0 8px;
    font-weight: 500;
    color: var(--fg);
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 8px;
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
  }

  .skill-pills li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 400;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    transition: border-color 150ms ease;
  }

  .project:hover .skill-pills li {
    border-color: var(--accent-cyan);
  }

  .project p:last-child {
    margin-bottom: 0;
  }

  .project a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .project a:hover {
    text-decoration-color: var(--accent);
  }

  /* ── Contact form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-form label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
  }

  .contact-input {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
    transition: border-color 150ms ease;
  }

  .contact-input:focus {
    outline: none;
    border-color: var(--accent-cyan);
  }

  .contact-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .contact-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-submit {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 10px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--fg);
    cursor: pointer;
    align-self: flex-start;
    transition:
      border-color 150ms ease,
      color 150ms ease;
  }

  .contact-submit:hover:not(:disabled) {
    border-color: var(--accent-cyan);
    color: var(--accent-cyan);
  }

  .contact-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .contact-status {
    margin-top: 12px;
    font-size: 0.85rem;
  }

  @media (max-width: 860px) {
    .hero {
      padding-top: 48px;
    }

    .hero-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .hero-image img {
      width: 132px;
      height: 132px;
    }

    .hero-content h1 {
      font-size: 1.8rem;
    }
  }
</style>
